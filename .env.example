# WorldQuant Brain
# Có thể ĐỂ TRỐNG hai dòng dưới — khi đó tool sẽ hỏi email/mật khẩu ngay trong
# PowerShell mỗi lần chạy (mật khẩu ẩn). Điền sẵn nếu muốn chạy không cần nhập.
WQ_EMAIL=
WQ_PASSWORD=

# DeepSeek (Phase 3)
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# LLM backend (LƯU Ý: tên biến KHÔNG có tiền tố WQ_, phải khớp field settings):
#   deepseek   = gọi DeepSeek API thật (tốn tiền)
#   claude-cli = tự gọi `claude -p` (Claude Code, dùng auth subscription, miễn phí)
#   codex-cli  = tự gọi `codex exec`
#   agent      = cầu nối qua file, phải có agent trực ghi resp_NNN.json (trả tay)
LLM_BACKEND=deepseek
# LLM_CLI_TIMEOUT_S=180   # trần thời gian mỗi lượt gọi CLI
# CLAUDE_BIN=claude       # đổi nếu lệnh không nằm trong PATH
# CODEX_BIN=codex

# Database
DATABASE_URL=sqlite:///wq_alpha.db

# Defaults
DEFAULT_REGION=USA
DEFAULT_UNIVERSE=TOP3000
DEFAULT_DELAY=1
